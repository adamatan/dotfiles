#!/bin/sh
# manual-install — Install tools not managed by Nix or Homebrew

gum style \
  --foreground 212 --border-foreground 212 --border double \
  --align center --width 40 --margin "1 2" \
  "Manual Installs"

install_tool() {
  name="$1"
  shift
  gum spin --spinner dot --title "Installing $name..." -- sh -c "$*"
  gum log --level info "$name installed"
}

install_tool "Claude Code" "curl -fsSL https://claude.ai/install.sh | bash"
